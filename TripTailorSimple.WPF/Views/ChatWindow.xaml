<Window x:Class="TripTailorSimple.WPF.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Assistant voyage"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F8F1EA">

    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F8F1EA"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#F7F7F7"/>
        <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="White"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#56B9E9"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#2D3A4B"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E3DDD7"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#1F2A37"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6B7280"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
        </Style>

        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D6D3D1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,10"/>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderBrush" Value="#D6D3D1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderBackgroundBrush}"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1">
            <Grid Margin="26,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="✈"
                               FontSize="24"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="TripTailor"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="White"
                        BorderBrush="#D6D3D1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18,10"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🧳"
                                   FontSize="14"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Assistant voyage"
                                   FontSize="14"
                                   Foreground="{StaticResource TextMainBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,24,0,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HERO -->
                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,24">
                    <TextBlock Text="Discute avec ton assistant voyage"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryDarkBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Pose tes questions sur les destinations, le budget, la météo ou les activités."
                               Margin="0,10,0,0"
                               FontSize="18"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                </StackPanel>

                <!-- MAIN CARD -->
                <Border Grid.Row="1"
                        Style="{StaticResource CardBorderStyle}"
                        Width="980"
                        HorizontalAlignment="Center"
                        Padding="28"
                        Margin="0,0,0,18">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- TITLE -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,18">
                            <TextBlock Text="Assistant intelligent"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Tu peux lui demander des idées de destinations, itinéraires, budget ou météo."
                                       Margin="0,8,0,0"
                                       FontSize="14"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>

                        <!-- CHAT AREA -->
                        <Border Grid.Row="1"
                                Background="White"
                                BorderBrush="#DDD6CF"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="18"
                                MinHeight="360">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="ChatBox"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="16"
                                         Foreground="{StaticResource TextMainBrush}"
                                         VerticalScrollBarVisibility="Disabled"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Text="IA : Bonjour ! Pose-moi une question."/>
                            </ScrollViewer>
                        </Border>

                        <!-- INPUT -->
                        <Grid Grid.Row="2" Margin="0,18,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="170"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="InputBox"
                                     Grid.Column="0"
                                     Height="50"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     KeyDown="InputBox_KeyDown"/>

                            <Button x:Name="SendButton"
                                    Grid.Column="1"
                                    Margin="14,0,0,0"
                                    Height="50"
                                    Content="Envoyer"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SendButton_Click"/>
                        </Grid>

                        <!-- STATUS -->
                        <Border Grid.Row="3"
                                Background="{StaticResource PrimaryBrush}"
                                CornerRadius="10"
                                Padding="14,10">
                            <TextBlock x:Name="StatusText"
                                       Text="Prêt"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- QUICK ACTIONS -->
                <Border Grid.Row="2"
                        Style="{StaticResource CardBorderStyle}"
                        Width="980"
                        HorizontalAlignment="Center"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Exemples de questions"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,14"/>

                        <WrapPanel>
                            <Button Content="Destination chaude en été"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Margin="0,0,10,10"/>
                            <Button Content="Voyage 7 jours budget 1500 €"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Margin="0,0,10,10"/>
                            <Button Content="Où partir en amoureux ?"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Margin="0,0,10,10"/>
                            <Button Content="Ville avec activités gratuites"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Margin="0,0,10,10"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>