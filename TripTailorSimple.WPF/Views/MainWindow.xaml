<Window x:Class="TripTailorSimple.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TripTailor"
        Height="940"
        Width="1500"
        MinHeight="840"
        MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F8F1EA">

    <Window.Resources>
        <SolidColorBrush x:Key="BgPage" Color="#F8F1EA"/>
        <SolidColorBrush x:Key="BgCard" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#E8E5E2"/>
        <SolidColorBrush x:Key="TextDark" Color="#1D2733"/>
        <SolidColorBrush x:Key="TextSoft" Color="#6F7A86"/>
        <SolidColorBrush x:Key="BlueMain" Color="#56B9E9"/>
        <SolidColorBrush x:Key="BlueDark" Color="#2D98B9"/>
        <SolidColorBrush x:Key="GreenSoft" Color="#32C48D"/>
        <SolidColorBrush x:Key="OrangeSoft" Color="#FF9B5C"/>

        <DropShadowEffect x:Key="SoftShadow"
                  BlurRadius="18"
                  ShadowDepth="3"
                  Opacity="0.15"
                  Color="#000000"/>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSoft}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource BlueDark}"/>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSoft}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FieldTitleStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SoftPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAFBFC"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="BigPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BlueMain}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Padding" Value="18,12"/>
        </Style>

        <Style x:Key="ModernChipStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BlueMain}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,12"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="22"/>
        </Style>

        <Style x:Key="ChipButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="MiniInfoTagStyle" TargetType="Border">
            <Setter Property="Background" Value="#F2F7F9"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgPage}">
        <Grid.RowDefinitions>
            <RowDefinition Height="78"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource BorderSoft}"
                BorderThickness="0,0,0,1">
            <Grid Margin="26,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="✈"
                               FontSize="20"
                               Foreground="{StaticResource BlueMain}"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="TripTailor"
                               FontSize="26"
                               FontWeight="Black"
                               Foreground="{StaticResource BlueMain}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button x:Name="BtnNavAccueil"
                            Content="Accueil"
                            Click="BtnNavAccueil_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="BtnNavDestinations"
                            Content="Destinations"
                            Click="BtnNavDestinations_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                   
                </StackPanel>

                <Button Grid.Column="2"
                         Content="🤖 Assistant voyage"
                         Width="150"
                         Height="38"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         Click="BtnOuvrirChat_Click"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="34">
                <!-- ACCUEIL -->
                <StackPanel x:Name="SectionAccueil">
                    <StackPanel Margin="0,8,0,26" HorizontalAlignment="Center">
                        <TextBlock Text="Trouvez votre destination idéale"
                   FontSize="38"
                   FontWeight="Black"
                   Foreground="{StaticResource TextDark}"
                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Choisis ton climat, ton budget, ta durée et tes régions. TripTailor te propose ensuite les meilleures destinations."
                   Margin="0,10,0,0"
                   FontSize="15"
                   Foreground="{StaticResource TextSoft}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   MaxWidth="860"
                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border Style="{StaticResource CardBorderStyle}"
            MaxWidth="1040"
            HorizontalAlignment="Center"
            Padding="28">
                        <StackPanel>

                            <!-- Ligne 1 -->
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                        Style="{StaticResource SoftPanelStyle}"
                        Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Recherche libre"
                                   Style="{StaticResource FieldTitleStyle}"/>
                                        <TextBox x:Name="TxtRechercheLibre"
                                 Height="40"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"
                                 Padding="12,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                        Style="{StaticResource SoftPanelStyle}"
                        Margin="10,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Saison de voyage"
                                   Style="{StaticResource FieldTitleStyle}"/>
                                        <ComboBox x:Name="ComboSaison"
                                  Height="40"
                                  FontSize="14"
                                  SelectedIndex="0">
                                            <ComboBoxItem Content="Été"/>
                                            <ComboBoxItem Content="Printemps"/>
                                            <ComboBoxItem Content="Automne"/>
                                            <ComboBoxItem Content="Hiver"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Ligne 2 -->
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                        Style="{StaticResource SoftPanelStyle}"
                        Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Préférence climatique"
                                   Style="{StaticResource FieldTitleStyle}"/>
                                        <ComboBox x:Name="ComboClimat"
                                  Height="40"
                                  FontSize="14"
                                  SelectedIndex="1">
                                            <ComboBoxItem Content="Chaud"/>
                                            <ComboBoxItem Content="Tempéré"/>
                                            <ComboBoxItem Content="Froid"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                        Style="{StaticResource SoftPanelStyle}"
                        Margin="10,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Nombre de jours"
                                   Style="{StaticResource FieldTitleStyle}"/>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="56"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Content="-"
                                    Grid.Column="0"
                                    Click="BtnMoinsJour_Click"
                                    FontSize="20"
                                    Style="{StaticResource SecondaryButtonStyle}"/>

                                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                                <TextBlock x:Name="TxtNombreJours"
                                           Text="7"
                                           FontSize="32"
                                           FontWeight="Black"
                                           Foreground="{StaticResource TextDark}"
                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="jours"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSoft}"
                                           HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                    Content="+"
                                    Click="BtnPlusJour_Click"
                                    FontSize="18"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Budget -->
                            <Border Style="{StaticResource SoftPanelStyle}" Margin="0,0,0,18">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Budget total"
                                   Style="{StaticResource FieldTitleStyle}"
                                   Margin="0"/>
                                        <TextBlock x:Name="TxtBudgetLabel"
                                   Grid.Column="1"
                                   Text="3100 €"
                                   FontSize="16"
                                   FontWeight="Black"
                                   Foreground="{StaticResource BlueDark}"/>
                                    </Grid>

                                    <Slider x:Name="SliderBudget"
                            Minimum="500"
                            Maximum="6000"
                            TickFrequency="100"
                            IsSnapToTickEnabled="True"
                            Value="2000"
                            ValueChanged="SliderBudget_ValueChanged"/>
                                </StackPanel>
                            </Border>

                            <!-- Style -->
                            <Border Style="{StaticResource SoftPanelStyle}" Margin="0,0,0,18">
                                <StackPanel>
                                    <TextBlock Text="Style de voyage"
                               Style="{StaticResource FieldTitleStyle}"/>
                                    <WrapPanel Margin="0,6,0,0">
                                        <Button x:Name="BtnStyleEconomique"
                                Content="Économique"
                                Click="BtnStyleEconomique_Click"
                                Style="{StaticResource ModernChipStyle}"/>
                                        <Button x:Name="BtnStyleConfort"
                                Content="Confort"
                                Click="BtnStyleConfort_Click"
                                Style="{StaticResource ModernChipStyle}"/>
                                        <Button x:Name="BtnStyleLuxe"
                                Content="Luxe"
                                Click="BtnStyleLuxe_Click"
                                Style="{StaticResource ModernChipStyle}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Régions -->
                            <Border Style="{StaticResource SoftPanelStyle}" Margin="0,0,0,18">
                                <StackPanel>
                                    <TextBlock Text="Régions du monde"
                               Style="{StaticResource FieldTitleStyle}"/>
                                    <WrapPanel Margin="0,6,0,0">
                                        <Button x:Name="BtnRegionEurope" Content="Europe" Tag="Europe" Click="BtnRegion_Click" Style="{StaticResource ModernChipStyle}"/>
                                        <Button x:Name="BtnRegionAfriqueNord" Content="Afrique du Nord" Tag="Afrique du Nord" Click="BtnRegion_Click" Style="{StaticResource ModernChipStyle}"/>
                                        <Button x:Name="BtnRegionAfriqueSub" Content="Afrique subsaharienne" Tag="Afrique subsaharienne" Click="BtnRegion_Click" Style="{StaticResource ModernChipStyle}"/>
                                        <Button x:Name="BtnRegionMoyenOrient" Content="Moyen-Orient" Tag="Moyen-Orient" Click="BtnRegion_Click" Style="{StaticResource ModernChipStyle}"/>
                                        <Button x:Name="BtnRegionAsie" Content="Asie" Tag="Asie" Click="BtnRegion_Click" Style="{StaticResource ModernChipStyle}"/>
                                        <Button x:Name="BtnRegionAsieSudEst" Content="Asie du Sud-Est" Tag="Asie du Sud-Est" Click="BtnRegion_Click" Style="{StaticResource ModernChipStyle}"/>
                                        <Button x:Name="BtnRegionAmeriqueNord" Content="Amérique du Nord" Tag="Amérique du Nord" Click="BtnRegion_Click" Style="{StaticResource ModernChipStyle}"/>
                                        <Button x:Name="BtnRegionCaraibes" Content="Caraïbes / Amérique Centrale" Tag="Caraïbes / Amérique Centrale" Click="BtnRegion_Click" Style="{StaticResource ModernChipStyle}"/>
                                        <Button x:Name="BtnRegionAmeriqueSud" Content="Amérique du Sud" Tag="Amérique du Sud" Click="BtnRegion_Click" Style="{StaticResource ModernChipStyle}"/>
                                        <Button x:Name="BtnRegionOceanie" Content="Océanie" Tag="Océanie" Click="BtnRegion_Click" Style="{StaticResource ModernChipStyle}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Options -->
                            <Border Style="{StaticResource SoftPanelStyle}" Margin="0,0,0,22">
                                <StackPanel>
                                    <TextBlock Text="Inclure dans le voyage"
                               Style="{StaticResource FieldTitleStyle}"/>
                                    <WrapPanel Margin="0,8,0,0">
                                        <CheckBox x:Name="ChkVolInclus" Content="Vol inclus" IsChecked="True" Margin="0,0,18,0"/>
                                        <CheckBox x:Name="ChkHotelInclus" Content="Hôtel inclus" IsChecked="True" Margin="0,0,18,0"/>
                                        <CheckBox x:Name="ChkActivitesPayantes" Content="Activités payantes" IsChecked="True" Margin="0,0,18,0"/>
                                        <CheckBox x:Name="ChkIdeesGratuites" Content="Idées gratuites" IsChecked="True"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- CTA -->
                            <Button x:Name="BtnRechercher"
                    Content="Trouver ma destination"
                    Click="BtnRechercher_Click"
                    Style="{StaticResource BigPrimaryButtonStyle}"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="0,34,0,0" HorizontalAlignment="Center">
                        <TextBlock Text="Inspirez-vous"
                   FontSize="34"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextDark}"
                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Pas d'idée précise ? Découvrez nos sélections prêtes à explorer"
                   Margin="0,8,0,24"
                   Foreground="{StaticResource TextSoft}"
                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <WrapPanel HorizontalAlignment="Center">
                        <Border Width="240" Height="190" Style="{StaticResource CardBorderStyle}" Margin="0,0,20,0" Background="#F7FBF8">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="✈" FontSize="28" HorizontalAlignment="Center" Margin="0,8,0,10"/>
                                <TextBlock Text="Week-end Économie" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="3 à 7 jours, petit budget," HorizontalAlignment="Center" Foreground="{StaticResource TextSoft}" Margin="0,8,0,0"/>
                                <TextBlock Text="destinations proches et" HorizontalAlignment="Center" Foreground="{StaticResource TextSoft}"/>
                                <TextBlock Text="charmantes" HorizontalAlignment="Center" Foreground="{StaticResource TextSoft}"/>
                                <Border Background="{StaticResource GreenSoft}" CornerRadius="10" Padding="10,4" HorizontalAlignment="Center" Margin="0,14,0,0">
                                    <TextBlock Text="ÉCONOMIE" Foreground="White" FontWeight="Bold" FontSize="11"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Width="240" Height="190" Style="{StaticResource CardBorderStyle}" Margin="0,0,20,0" Background="#F7FBFD">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="🌍" FontSize="28" HorizontalAlignment="Center" Margin="0,8,0,10"/>
                                <TextBlock Text="Voyage Confort" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="7 à 10 jours, budget équilibré," HorizontalAlignment="Center" Foreground="{StaticResource TextSoft}" Margin="0,8,0,0"/>
                                <TextBlock Text="destinations variées" HorizontalAlignment="Center" Foreground="{StaticResource TextSoft}"/>
                                <Border Background="{StaticResource BlueMain}" CornerRadius="10" Padding="10,4" HorizontalAlignment="Center" Margin="0,14,0,0">
                                    <TextBlock Text="CONFORT" Foreground="White" FontWeight="Bold" FontSize="11"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Width="240" Height="190" Style="{StaticResource CardBorderStyle}" Background="#FFF8F3">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="💎" FontSize="28" HorizontalAlignment="Center" Margin="0,8,0,10"/>
                                <TextBlock Text="Expérience Luxe" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="7 à 14 jours, budget généreux," HorizontalAlignment="Center" Foreground="{StaticResource TextSoft}" Margin="0,8,0,0"/>
                                <TextBlock Text="hôtels premium et expériences" HorizontalAlignment="Center" Foreground="{StaticResource TextSoft}"/>
                                <TextBlock Text="uniques" HorizontalAlignment="Center" Foreground="{StaticResource TextSoft}"/>
                                <Border Background="{StaticResource OrangeSoft}" CornerRadius="10" Padding="10,4" HorizontalAlignment="Center" Margin="0,14,0,0">
                                    <TextBlock Text="LUXE" Foreground="White" FontWeight="Bold" FontSize="11"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <TextBlock Text="© 2025 TripTailor — votre aventure sur mesure, partout dans le monde"
               Margin="0,24,0,12"
               HorizontalAlignment="Center"
               Foreground="{StaticResource TextSoft}"/>
                </StackPanel>

                <!-- RESULTATS -->
                <StackPanel x:Name="SectionResultats" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Button Content="← Retour"
                                Click="BtnRetourAccueil_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,14,0"/>
                        <TextBlock x:Name="TxtNombreResultats"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSoft}"/>
                    </StackPanel>

                    <WrapPanel x:Name="PanelResultats"/>
                </StackPanel>

                <!-- DETAIL -->
                <StackPanel x:Name="SectionDetail" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Button Content="← Retour résultats"
                                Click="BtnRetourResultats_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,12,0"/>
                        <Button Content="Voir les vols"
                                Click="BtnVoirVols_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,12,0"/>
                        <Button Content="Voir l'hôtel"
                                Click="BtnVoirHotel_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,12,0"/>
                        <Button Content="Voir activités"
                                Click="BtnVoirActivites_Click"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>

                    <Border Height="290"
                            CornerRadius="22"
                            BorderBrush="{StaticResource BorderSoft}"
                            BorderThickness="1"
                            Background="White"
                            Margin="0,0,0,22">
                        <Grid>
                            <Image x:Name="ImgDestinationHero" Stretch="Fill"/>
                            <Border CornerRadius="22">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#22000000" Offset="0"/>
                                        <GradientStop Color="#77000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Border Style="{StaticResource MiniInfoTagStyle}" Background="White">
                                        <TextBlock x:Name="TxtDetailRegionShort" FontWeight="Bold" FontSize="11"/>
                                    </Border>
                                    <Border Style="{StaticResource MiniInfoTagStyle}" Background="{StaticResource BlueMain}">
                                        <TextBlock x:Name="TxtDetailStyle" FontWeight="Bold" FontSize="11" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="TxtVillePays"
                                           Margin="0,12,0,10"
                                           FontSize="42"
                                           FontWeight="Black"
                                           Foreground="White"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtRegionPays"
                                           FontSize="16"
                                           Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,22">
                        <StackPanel>
                            <TextBlock Text="À propos de la destination"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BlueDark}"/>
                            <TextBlock x:Name="TxtDescription"
                                       Margin="0,14,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSoft}"
                                       FontSize="15"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,22">
                        <StackPanel>
                            <TextBlock Text="Prévisions météo"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BlueDark}"/>
                            <WrapPanel x:Name="PanelPrevisionsMeteo" Margin="0,18,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,22">
                        <StackPanel>
                            <TextBlock Text="Réservez votre voyage"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BlueDark}"/>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        BorderBrush="{StaticResource BorderSoft}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="18"
                                        Background="#FCFCFC"
                                        Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="✈ Rechercher un vol"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextDark}"/>
                                        <TextBlock x:Name="TxtCompagnieSuggeree"
                                                   Margin="0,12,0,4"
                                                   Foreground="{StaticResource TextSoft}"/>
                                        <TextBlock x:Name="TxtLienVol"
                                                   Foreground="{StaticResource BlueDark}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        BorderBrush="{StaticResource BorderSoft}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="18"
                                        Background="#FCFCFC"
                                        Margin="10,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="🏨 Hôtel conseillé"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextDark}"/>
                                        <TextBlock x:Name="TxtHotelSuggere"
                                                   Margin="0,12,0,4"
                                                   Foreground="{StaticResource TextSoft}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="TxtHotelLien"
                                                   Foreground="{StaticResource BlueDark}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,22">
                        <StackPanel>
                            <TextBlock Text="Votre programme type"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BlueDark}"/>
                            <StackPanel x:Name="PanelProgramme" Margin="0,18,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,22">
                        <StackPanel>
                            <TextBlock Text="Activités à découvrir"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BlueDark}"/>
                            <StackPanel x:Name="PanelActivitesPayantes" Margin="0,18,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,22">
                        <StackPanel>
                            <TextBlock Text="Idées gratuites"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BlueDark}"/>
                            <StackPanel x:Name="PanelIdeesGratuites" Margin="0,18,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,22">
                        <StackPanel>
                            <TextBlock Text="Détail du prix"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BlueDark}"/>

                            <Grid Margin="0,18,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TxtPrixVolLabel" Foreground="{StaticResource TextSoft}" FontSize="16"/>
                                <TextBlock x:Name="TxtPrixVolValeur" Grid.Column="1" Foreground="{StaticResource TextSoft}" FontSize="16"/>
                            </Grid>

                            <Separator/>

                            <Grid Margin="0,12,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TxtPrixHotelLabel" Foreground="{StaticResource TextSoft}" FontSize="16"/>
                                <TextBlock x:Name="TxtPrixHotelValeur" Grid.Column="1" Foreground="{StaticResource TextSoft}" FontSize="16"/>
                            </Grid>

                            <Separator/>

                            <Grid Margin="0,12,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TxtPrixActivitesLabel" Foreground="{StaticResource TextSoft}" FontSize="16"/>
                                <TextBlock x:Name="TxtPrixActivitesValeur" Grid.Column="1" Foreground="{StaticResource TextSoft}" FontSize="16"/>
                            </Grid>

                            <Separator/>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Total"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource BlueDark}"/>
                                <TextBlock x:Name="TxtPrixTotal"
                                           Grid.Column="1"
                                           FontSize="24"
                                           FontWeight="Black"
                                           Foreground="{StaticResource BlueDark}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>